broker:
  name: Rakuten Securities
  account_type: general  # general / specific-withholding / specific-no-withholding / NISA

fees:
  us_stock:
    rate: 0.00495       # 0.495% of trade amount
    min_usd: 0
    max_usd: 22
    sec_fee: 0.0000206  # On sell orders only
  jp_stock:
    rate: 0             # Zero-commission plan etc.
  asean_stock:
    rate: 0.011         # 1.1% of trade amount
  fx:
    realtime_spread: 0  # Real-time FX: 0 pips
    scheduled_spread: 0 # Scheduled FX: 0 pips

tax:
  capital_gains_rate: 0.20315  # Income tax 15.315% + resident tax 5%
  needs_filing: true           # true for general accounts
  realized_losses_ytd: 0       # Realized losses this year (for loss offset, update manually)
